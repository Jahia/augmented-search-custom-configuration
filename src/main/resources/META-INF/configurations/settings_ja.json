{
  "requires": "analysis-kuromoji",
  "tokenizer": {
    "ja_tokenizer": {
      "type": "kuromoji_tokenizer",
      "mode": "extended"
    }
  },
  "analyzer": {
    "type": "kuromoji",
    "mode": "extended"
  },
  "stopwords": {
    "type": "ja_stop"
  },
  "stemmer": {
    "type": "kuromoji_stemmer",
    "minimum_length": 2
  }
}
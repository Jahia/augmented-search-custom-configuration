{
  "index.indexing.slowlog.threshold": {
    "index.warn": "10s",
    "index.trace": "500ms",
    "index.debug": "2s",
    "index.info": "5s"
  },
  "index.search.slowlog.threshold": {
    "query.warn": "2000ms",
    "query.trace": "500ms",
    "query.debug": "1000ms",
    "query.info": "1500ms",
    "fetch.warn": "1000ms",
    "fetch.trace": "200ms",
    "fetch.debug": "300ms",
    "fetch.info": "800ms"
  },
  "analysis": {
    "filter": {
      "phrase_shingle": {
        "max_shingle_size": "3",
        "min_shingle_size": "2",
        "output_unigrams": "true",
        "type": "shingle"
      },
      "i18n-stop-words-filter": {
        "type": "stop",
        "stopwords": "_english_"
      },
      "i18n-stem-filter": {
        "type": "stemmer",
        "name": "english"
      },
      "delimiter": {
        "split_on_numerics": true,
        "generate_word_parts": true,
        "preserve_original": false,
        "catenate_words": true,
        "generate_number_parts": true,
        "catenate_all": true,
        "split_on_case_change": true,
        "type": "word_delimiter_graph",
        "catenate_numbers": true,
        "stem_english_possessive": true
      },
      "unique_stem": {
        "type": "unique",
        "only_on_same_position": true
      },
      "ascii_folding": {
        "type": "asciifolding",
        "preserve_original": true
      },
      "catalan_elision": {
        "type": "elision",
        "articles": [
          "d",
          "l",
          "m",
          "n",
          "s",
          "t"
        ]
      },
      "french_elision": {
        "type": "elision",
        "articles_case": true,
        "articles": [
          "l",
          "m",
          "t",
          "qu",
          "n",
          "s",
          "j",
          "d",
          "c",
          "jusqu",
          "quoiqu",
          "lorsqu",
          "puisqu"
        ]
      },
      "irish_elision": {
        "type": "elision",
        "articles": [
          "h",
          "n",
          "t"
        ]
      },
      "italian_elision": {
        "type": "elision",
        "articles": [
          "c",
          "l",
          "all",
          "dall",
          "dell",
          "nell",
          "sull",
          "coll",
          "pell",
          "gl",
          "agl",
          "dagl",
          "degl",
          "negl",
          "sugl",
          "un",
          "m",
          "t",
          "s",
          "v",
          "d"
        ]
      }
    },
    "analyzer": {
      "text_base": {
        "char_filter": [
          "html_strip",
          "icu_normalizer"
        ],
        "filter": [
          "cjk_width",
          "lowercase",
          "icu_folding",
          "i18n-stop-words-filter"
        ],
        "tokenizer": "icu_tokenizer"
      },
      "text_stem": {
        "char_filter": [
          "html_strip",
          "icu_normalizer"
        ],
        "filter": [
          "cjk_width",
          "lowercase",
          "icu_folding",
          "i18n-stop-words-filter",
          "i18n-stem-filter"
        ],
        "tokenizer": "icu_tokenizer"
      },
      "main_analyzer": {
        "tokenizer": "main_tokenizer",
        "char_filter": [
          "html_strip"
        ],
        "filter": [
          "cjk_width",
          "lowercase",
          "i18n-stop-words-filter"
        ]
      },
      "metadata_analyzer": {
        "tokenizer": "metadata_tokenizer",
        "filter": [
          "cjk_width",
          "lowercase",
          "icu_folding"
        ]
      },
      "phrase_shingle_analyzer": {
        "char_filter": [
          "html_strip",
          "icu_normalizer"
        ],
        "filter": [
          "cjk_width",
          "lowercase",
          "icu_folding",
          "i18n-stop-words-filter",
          "phrase_shingle"
        ],
        "tokenizer": "icu_tokenizer"
      },
      "keyword_base": {
        "filter": [
          "cjk_width",
          "lowercase",
          "i18n-stop-words-filter"
        ],
        "tokenizer": "keyword"
      },
      "stemmed_and_unstemmed": {
        "char_filter": [
          "html_strip",
          "icu_normalizer"
        ],
        "type": "custom",
        "tokenizer": "icu_tokenizer",
        "filter": [
          "lowercase",
          "icu_folding",
          "keyword_repeat",
          "porter_stem",
          "unique_stem"
        ]
      },
      "path_hierarchy_analyzer": {
        "tokenizer": "path_hierarchy_tokenizer",
        "filter": [
          "lowercase"
        ]
      },
      "category_path_analyzer": {
        "tokenizer": "category_path_tokenizer"
      }
    },
    "tokenizer": {
      "path_hierarchy_tokenizer": {
        "type": "path_hierarchy",
        "replacement": "/",
        "skip": 0
      },
      "category_path_tokenizer": {
        "type": "path_hierarchy",
        "delimiter": ">",
        "replacement": "/",
        "skip": 0
      },
      "main_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 12,
        "token_chars": [
          "letter",
          "digit"
        ]
      },
      "metadata_tokenizer": {
        "type": "edge_ngram",
        "min_gram": 1,
        "max_gram": 12,
        "token_chars": [
          "letter",
          "digit"
        ]
      }
    }
  }
}
